# ===========================================
# VARIABLES DE ENTORNO - USUARIOS-SERVICE
# ===========================================
# NUNCA commit .env con valores reales

# -------------------------------------------
# JWT (debe coincidir con auth-service)
# -------------------------------------------
# Secret key DEBE tener mínimo 32 caracteres para HS256
# Generar con: openssl rand -base64 32
JWT_SECRET=mi-secret-super-seguro-de-al-menos-32-caracteres-para-hs256

# -------------------------------------------
# DATABASE (PostgreSQL)
# -------------------------------------------
DB_URL=jdbc:postgresql://localhost:5432/usuarios_db
DB_USERNAME=guest
DB_PASSWORD=guest
POSTGRES_PASSWORD=guest

# -------------------------------------------
# RABBITMQ
# -------------------------------------------
RABBITMQ_ADDRESSES=amqp://guest:guest@localhost:5672

# -------------------------------------------
# APPLICATION
# -------------------------------------------
SERVER_PORT=8081
SPRING_PROFILES_ACTIVE=dev
