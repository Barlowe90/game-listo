# ============================================
# GAME-LISTO - VARIABLES DE ENTORNO
# ============================================
# Copia este archivo a .env y configura los valores según tu entorno

# ============================================
# JWT SECRET (IMPORTANTE: Cambia en producción)
# ============================================
# Debe ser el mismo en api-gateway y usuarios-service
# Longitud recomendada: mínimo 256 bits (32 caracteres)
# IMPORTANTE: Evita usar caracteres especiales como { } [ ] $ que causan problemas en Docker Compose
# Usa solo letras, números, guiones y guiones bajos para evitar problemas de escape
JWT_SECRET=genera-un-secreto-aleatorio-de-al-menos-32-caracteres

# ============================================
# SPRING DATASOURCE
# ============================================
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/usuarios_db
SPRING_DATASOURCE_USERNAME=guest
SPRING_DATASOURCE_PASSWORD=guest

# ============================================
# BASE DE DATOS - PostgreSQL
# ============================================
POSTGRES_USER=guest
POSTGRES_PASSWORD=guest
POSTGRES_DB=usuarios_db

# ============================================
# RABBITMQ
# ============================================
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# ============================================
# MONGODB
# ============================================
MONGO_USER=root
MONGO_PASSWORD=example

# ============================================
# IGDB API (para catalogo-service)
# ============================================
# Obtener credenciales en: https://dev.twitch.tv/console/apps
IGDB_CLIENT_ID=your-client-id-here
# Obtener token con: curl -X POST "https://id.twitch.tv/oauth2/token" -d "client_id=...&client_secret=...&grant_type=client_credentials"
IGDB_ACCESS_TOKEN=your-access-token-here

# ============================================
# REDIS
# ============================================
REDIS_PASSWORD=
