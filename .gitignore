
# ----------------------
# Ignorar artefactos comunes
# ----------------------

# Sistema / SO
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDEs
.idea/
*.iml
*.iws
.vscode/

# Java / Maven
# Ignora todos los directorios target en submódulos
**/target/
*.class
*.jar
*.war
*.ear
hs_err_pid*
replay_pid*

# Maven local repo
.m2/

# Build / artefactos generados
build/
out/
generated/
bin/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker / env
.env
.env.local
.env.*.local
docker-compose.override.yml

# Secrets & certificates
**/application-local.properties
**/application-prod.properties
secrets/
credentials/
*.pem
*.key
*.crt
*.p12
*.jks

# Node / Frontend (Next.js / Vite / pnpm)
node_modules/
**/node_modules/
.next/
frontend/.next/
out/
dist/
.vite/
.pnpm-store/
.pnpm-debug.log

# Frontend-specific generated types
frontend/.turbo/
frontend/next-env.d.ts

# Test / coverage
coverage/
jacoco.exec
surefire-reports/
target/surefire-reports/

# Misc
*.swp
*~
*.bak
*.tmp

# Notes:
# - Si algún target/ ya estaba trackeado, deberás quitarlo del índice con git rm --cached.
# - Este archivo cubre reglas comunes; las reglas adicionales específicas por subproyecto
#   pueden ir en el .gitignore de cada subcarpeta si lo deseas.
