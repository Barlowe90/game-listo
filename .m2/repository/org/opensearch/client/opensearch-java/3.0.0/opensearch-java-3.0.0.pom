    </developer>
  </developers>
  <scm>
    <connection>scm:git@github.com:opensearch-project/opensearch-java.git</connection>
    <developerConnection>scm:git@github.com:opensearch-project/opensearch-java.git</developerConnection>
    <url>git@github.com:opensearch-project/opensearch-java.git</url>
  </scm>
